  "info": {
    "name": "CPU Asset API Test - Multi-Collection Saving",
    "description": "Postman template for creating CPU assets. Single request saves to 3 collections: asset_fixed, asset_purchases, asset_warranties",
    "created": "2026-03-23",
    "flowExplanation": "1. Frontend sends 1 request with all fields → 2. Backend saves fixed asset → 3. Backend extracts & saves purchase → 4. Backend extracts & saves warranty → 5. Response returns all 3 docs"
  },
  "endpoint": "POST /api/v1/assets",
  "baseUrl": "http://localhost:4000",
  "notes": [
    "Replace REPLACE_WITH_ACTUAL_BRANCH_ID with actual branch ObjectId from database",
    "Change itemType to 'laptop' or 'monitor' to test other asset types",
    "Purchase and Warranty docs are created only if fields have values",
    "All Purchase/Warranty fields shown below are optional - include only needed fields",
    "Response includes: fixedAsset (_id needed for later queries), purchase (with assetId link), warranty (with assetId link)",
    "Send Authorization header: Bearer <token>"
  ],
